{
    "name": "gravit-web-v2",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "preinstall": "npx only-allow pnpm",
        "format": "biome format --write",
        "check": "biome check --write",
        "lint": "pnpm lint:biome",
        "openapi": "openapi-generator-cli generate -i https://grav-it-dev.inuappcenter.kr/v3/api-docs -g typescript-axios -o ./src/shared/api/@generated --skip-validate-spec -c openapitools.json",
        "orval": "orval",
        "lint:biome": "biome lint --write",
        "ci": "biome ci .",
        "router:generate": "tanstack-router-generate",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build"
    },
    "dependencies": {
        "@floating-ui/react": "^0.27.19",
        "@radix-ui/react-scroll-area": "^1.2.10",
        "@radix-ui/themes": "^3.3.0",
        "@tanstack/react-query": "^5.87.4",
        "@tanstack/react-query-devtools": "^5.87.4",
        "@tanstack/react-router": "^1.131.36",
        "@tanstack/react-router-devtools": "^1.131.36",
        "axios": "^1.12.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "hast-util-sanitize": "^5.0.2",
        "react": "^19.1.1",
        "react-dom": "^19.1.1",
        "react-intersection-observer": "^10.0.3",
        "react-markdown": "^10.1.0",
        "react-responsive": "^10.0.1",
        "rehype-autolink-headings": "^7.1.0",
        "rehype-raw": "^7.0.0",
        "rehype-sanitize": "^6.0.0",
        "rehype-slug": "^6.0.0",
        "remark-gfm": "^4.0.1",
        "tailwind-merge": "^3.3.1",
        "tailwind-scrollbar-hide": "^4.0.0",
        "zod": "^4.1.11",
        "zustand": "^5.0.8"
    },
    "devDependencies": {
        "@biomejs/biome": "2.2.4",
        "@chromatic-com/storybook": "^5.1.2",
        "@eslint/js": "^9.33.0",
        "@openapitools/openapi-generator-cli": "^2.25.2",
        "@storybook/addon-a11y": "^10.3.6",
        "@storybook/addon-docs": "^10.3.6",
        "@storybook/addon-vitest": "^10.3.6",
        "@storybook/react-vite": "^10.3.6",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.1.13",
        "@tanstack/eslint-plugin-query": "^5.86.0",
        "@tanstack/router-plugin": "^1.131.36",
        "@types/node": "^24.3.1",
        "@types/react": "^19.1.10",
        "@types/react-dom": "^19.1.7",
        "@vitejs/plugin-react": "^5.0.0",
        "eslint": "^9.33.0",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.20",
        "eslint-plugin-storybook": "^10.3.6",
        "globals": "^16.3.0",
        "only-allow": "^1.2.1",
        "orval": "^8.11.0",
        "storybook": "^10.3.6",
        "tailwindcss": "^4.1.13",
        "typescript": "~5.8.3",
        "typescript-eslint": "^8.39.1",
        "vite": "^7.1.2",
        "vite-plugin-svgr": "^4.5.0"
